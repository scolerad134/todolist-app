#Подключение golang образа
FROM golang:1.26.2-bookworm AS builder
#Создание рабочей директории внутри docker-контейнера golang и переход в нее
WORKDIR /app
#Копирование файлов с зависимостями в рабочую директорию docker-контейнера
COPY go.mod go.sum ./
#Установка всех зависимостей, указанных в go.mod в контейнер
RUN go mod download
#Копирование всех файлов проекта в рабочую директорию /app в контейнере
COPY . .
#Сборка проекта и создание исполняемого файла .exe и помещение его в директорию /cmd/todoapp/ с названием exe в контейнере
#Вторым параметром указан путь к файлу main.go
RUN CGO_ENABLED=0 go build -o /app/cmd/todoapp/exe /app/cmd/todoapp
#-----------------------------------------------------------------------------------------------------------------------
#Подключение минималистичного linux образа для запуска бинарного файла приложения
FROM alpine:3.23
#Создание рабочей директории внутри docker-контейнера linux и переход в нее
WORKDIR /app
#Копирование исполняемого файла из stage builder
COPY --from=builder /app/cmd/todoapp/exe /app
#Запуск исполняемого файла exe
CMD ["/app/exe"]